// FUNCIONES PARA TICKETS
function generarNumeroTicket() {
    $prefijo = 'CSI';
    $fecha = date('Ymd');
    $random = str_pad(rand(1, 9999), 4, '0', STR_PAD_LEFT);
    return $prefijo . '-' . $fecha . '-' . $random;
}

