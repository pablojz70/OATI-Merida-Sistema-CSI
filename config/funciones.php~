// FUNCIONES DE HISTORIAL
function registrarHistorial($ticket_id, $accion, $descripcion = '') {
    if (session_status() === PHP_SESSION_NONE) {
        session_start();
    }
    
    $usuario_id = $_SESSION['usuario_id'] ?? 0;
    $sql = "INSERT INTO HistorialTickets (ticket_id, usuario_id, accion, descripcion) VALUES (?, ?, ?, ?)";
    ejecutarConsulta($sql, [
        $ticket_id,
        $usuario_id,
        $accion,
        $descripcion
    ]);
}

// FUNCIONES DE ESTADÍSTICAS
function obtenerEstadisticasTickets($usuario_id = null) {
    $estadisticas = [];
    
    // Total tickets
    if ($usuario_id) {
        $sql = "SELECT COUNT(*) as total FROM Tickets WHERE usuario_id = ?";
        $result = obtenerFila($sql, [$usuario_id]);
        $estadisticas['total'] = $result['total'];
        
        // Por estado
        $sql = "SELECT estado, COUNT(*) as cantidad FROM Tickets WHERE usuario_id = ? GROUP BY estado";
        $estados = obtenerTodasFilas($sql, [$usuario_id]);
    } else {
        $sql = "SELECT COUNT(*) as total FROM Tickets";
        $result = obtenerFila($sql);
        $estadisticas['total'] = $result['total'];
        
        // Por estado
        $sql = "SELECT estado, COUNT(*) as cantidad FROM Tickets GROUP BY estado";
        $estados = obtenerTodasFilas($sql);
    }
    
    // Organizar por estado
    $estadisticas['estados'] = [];
    foreach ($estados as $estado) {
        $estadisticas['estados'][$estado['estado']] = $estado['cantidad'];
    }
    
    return $estadisticas;
}

function obtenerTicketsPorUsuario($usuario_id, $limit = 10) {
    $sql = "SELECT t.*, a.nombre as area_nombre, s.nombre as servicio_nombre 
            FROM Tickets t
            JOIN AreasSoporte a ON t.area_id = a.id
            JOIN Servicios s ON t.servicio_id = s.id
            WHERE t.usuario_id = ?
            ORDER BY t.fecha_creacion DESC
            LIMIT ?";
    return obtenerTodasFilas($sql, [$usuario_id, $limit]);
}

// FUNCIONES DE VALIDACIÓN
function validarEmail($email) {
    return filter_var($email, FILTER_VALIDATE_EMAIL);
}

function sanitizarTexto($texto) {
    return htmlspecialchars(trim($texto), ENT_QUOTES, 'UTF-8');
}

function validarLongitud($texto, $min = 1, $max = 255) {
    $longitud = strlen(trim($texto));
    return $longitud >= $min && $longitud <= $max;
}

// FUNCIONES DE FORMATO
function formatoFecha($fecha, $formato = 'd/m/Y H:i:s') {
    if (!$fecha) return '';
    return date($formato, strtotime($fecha));
}

function formatoTiempo($segundos) {
    $horas = floor($segundos / 3600);
    $minutos = floor(($segundos % 3600) / 60);
    $segundos = $segundos % 60;
    
    return sprintf('%02d:%02d:%02d', $horas, $minutos, $segundos);
}

// FUNCIONES DE ARCHIVOS
function extensionPermitida($nombre_archivo) {
    $extensiones = ['pdf', 'doc', 'docx', 'xls', 'xlsx', 'jpg', 'jpeg', 'png', 'gif', 'txt'];
    $extension = strtolower(pathinfo($nombre_archivo, PATHINFO_EXTENSION));
    return in_array($extension, $extensiones);
}

function tamañoValido($tamaño) {
    $max_tamaño = 10 * 1024 * 1024; // 10MB
    return $tamaño <= $max_tamaño;
}

